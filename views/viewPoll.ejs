<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= poll ? poll.title : "Poll Not Found" %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg-ink: #06141b;
            --bg-deep: #0a2430;
            --card-border: rgba(255, 255, 255, 0.18);
            --text-main: #eff8ff;
            --text-muted: #b8d0df;
            --text-soft: #d4ecf8;
            --accent: #00c2a8;
            --accent-strong: #00a08c;
            --secondary: #5b8cff;
            --soft-glow: rgba(0, 194, 168, 0.22);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            font-family: "Space Grotesk", sans-serif;
            color: var(--text-main);
            background:
                radial-gradient(1200px 700px at 88% -12%, rgba(0, 194, 168, 0.22), transparent 58%),
                radial-gradient(900px 560px at 8% 108%, rgba(91, 140, 255, 0.18), transparent 55%),
                linear-gradient(135deg, var(--bg-ink), var(--bg-deep));
        }

        .page-shell {
            min-height: 100vh;
            padding: 28px;
            position: relative;
            overflow: hidden;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            filter: blur(52px);
            opacity: 0.55;
            z-index: 0;
            animation: float 9s ease-in-out infinite;
        }

        .blob-a {
            width: 230px;
            height: 230px;
            top: 8%;
            left: 8%;
            background: rgba(0, 194, 168, 0.24);
        }

        .blob-b {
            width: 240px;
            height: 240px;
            right: 10%;
            bottom: 8%;
            background: rgba(91, 140, 255, 0.18);
            animation-delay: 2.2s;
        }

        .container {
            width: min(1024px, 100%);
            margin: 0 auto;
            position: relative;
            z-index: 1;
            animation: fadeUp 560ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 22px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
            padding: 10px 14px;
            border-radius: 12px;
            transition: transform 0.2s ease, background-color 0.2s ease;
        }

        .back-link:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.12);
        }

        .hero-card {
            padding: clamp(24px, 4vw, 40px);
            border-radius: 28px;
            border: 1px solid var(--card-border);
            background: linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.05));
            backdrop-filter: blur(10px);
            box-shadow: 0 24px 80px rgba(2, 18, 24, 0.56);
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: var(--text-soft);
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 999px;
            padding: 8px 12px;
            margin-bottom: 16px;
        }

        .eyebrow-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 0 8px var(--soft-glow);
        }

        .page-title {
            font-size: clamp(2rem, 4.4vw, 3rem);
            line-height: 1.08;
            margin-bottom: 10px;
        }

        .page-subtitle {
            color: var(--text-muted);
            line-height: 1.7;
            max-width: 62ch;
            margin-bottom: 28px;
        }

        .details-grid {
            display: grid;
            grid-template-columns: 1.15fr 0.85fr;
            gap: 18px;
        }

        .panel {
            border-radius: 22px;
            border: 1px solid var(--card-border);
            background: rgba(255, 255, 255, 0.06);
            padding: 20px;
        }

        .panel-title {
            font-size: 1.15rem;
            margin-bottom: 14px;
        }

        .meta-list {
            display: grid;
            gap: 12px;
        }

        .meta-item {
            padding: 14px 16px;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .meta-label {
            display: block;
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .meta-value {
            color: var(--text-main);
            line-height: 1.6;
            word-break: break-word;
        }

        .stats-head {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 14px;
        }

        .stats-box {
            padding: 12px;
            border-radius: 14px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            background: rgba(255, 255, 255, 0.05);
        }

        .stats-label {
            display: block;
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .stats-value {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .results-list {
            display: grid;
            gap: 10px;
            margin-bottom: 16px;
        }

        .result-item {
            padding: 12px;
            border-radius: 14px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            background: rgba(255, 255, 255, 0.05);
        }

        .result-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
        }

        .result-name {
            font-size: 0.92rem;
            color: var(--text-main);
            font-weight: 600;
            word-break: break-word;
        }

        .result-numbers {
            font-size: 0.84rem;
            color: var(--text-soft);
            white-space: nowrap;
        }

        .progress-track {
            height: 10px;
            width: 100%;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.12);
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, var(--secondary), var(--accent));
            box-shadow: 0 6px 20px rgba(91, 140, 255, 0.28);
            transition: width 0.35s ease;
        }

        .options-list {
            display: grid;
            gap: 12px;
        }

        .option-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            background: rgba(255, 255, 255, 0.06);
        }

        .option-radio {
            width: 18px;
            height: 18px;
            accent-color: var(--accent);
            flex: 0 0 auto;
        }

        .option-text {
            flex: 1;
            color: var(--text-main);
        }

        .actions {
            margin-top: 18px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn {
            appearance: none;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 18px;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        .btn-primary {
            color: #05232a;
            background: linear-gradient(135deg, var(--accent), var(--accent-strong));
            box-shadow: 0 10px 28px var(--soft-glow);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 34px rgba(0, 194, 168, 0.26);
        }

        .btn-secondary {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }

        .btn-secondary:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.12);
        }

        .empty-state {
            padding: 42px 24px;
            border-radius: 22px;
            border: 1px dashed rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.06);
            text-align: center;
            color: var(--text-muted);
        }

        .empty-state h2 {
            color: var(--text-main);
            margin-bottom: 8px;
            font-size: 1.4rem;
        }

        .empty-state p {
            line-height: 1.7;
            max-width: 52ch;
            margin: 0 auto;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-14px);
            }
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(14px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 820px) {
            .details-grid {
                grid-template-columns: 1fr;
            }

            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @media (max-width: 640px) {
            .page-shell {
                padding: 16px;
            }

            .hero-card {
                padding: 20px;
                border-radius: 20px;
            }

            .actions {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }

            .stats-head {
                grid-template-columns: 1fr;
            }
        }

        @media (prefers-reduced-motion: reduce) {

            *,
            *::before,
            *::after {
                animation: none !important;
                transition: none !important;
            }
        }
    </style>
</head>

<body>
    <div class="page-shell">
        <div class="blob blob-a" aria-hidden="true"></div>
        <div class="blob blob-b" aria-hidden="true"></div>

        <div class="container">
            <div class="topbar">
                <a class="back-link" href="/polls">← Back to Polls</a>
                <div class="eyebrow">
                    <span class="eyebrow-dot"></span>
                    Poll Details
                </div>
            </div>

            <% if (poll) { %>
                <% const pollResult=Array.isArray(result) ? result : []; %>
                    <section class="hero-card">
                        <h1 class="page-title">
                            <%= poll.title %>
                        </h1>
                        <% if (poll.description) { %>
                            <p class="page-subtitle">
                                <%= poll.description %>
                            </p>
                            <% } else { %>
                                <p class="page-subtitle">No description was provided for this poll.</p>
                                <% } %>

                                    <div class="details-grid">
                                        <div class="panel">
                                            <h2 class="panel-title">What is Your Opinion</h2>

                                            <form action="/polls/<%= poll._id %>" method="POST">
                                                <div class="options-list">
                                                    <% if (poll.options && poll.options.length> 0) { %>
                                                        <% poll.options.forEach(function(option) { %>
                                                            <label class="option-item">
                                                                <input class="option-radio" type="radio"
                                                                    name="pollOption" value="<%= option._id %>">
                                                                <span class="option-text">
                                                                    <%= option.name %>
                                                                </span>
                                                            </label>
                                                            <% }); %>
                                                                <% } else { %>
                                                                    <div class="empty-state">
                                                                        <h2>No options available</h2>
                                                                        <p>This poll currently does not have any voting
                                                                            options.</p>
                                                                    </div>
                                                                    <% } %>
                                                </div>

                                                <% if (poll.options && poll.options.length> 0) { %>
                                                    <div class="actions">
                                                        <button class="btn btn-primary" type="submit">Submit Your
                                                            Opinion</button>
                                                        <a class="btn btn-secondary" href="/polls">View All Polls</a>
                                                    </div>
                                                    <% } %>
                                            </form>
                                        </div>

                                        <aside class="panel">
                                            <h2 class="panel-title">Live Results</h2>
                                            <div class="stats-head">
                                                <div class="stats-box">
                                                    <span class="stats-label">Total Votes</span>
                                                    <span class="stats-value">
                                                        <%= poll.totalVote || 0 %>
                                                    </span>
                                                </div>
                                                <div class="stats-box">
                                                    <span class="stats-label">Total Options</span>
                                                    <span class="stats-value">
                                                        <%= poll.options ? poll.options.length : 0 %>
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="results-list">
                                                <% if (pollResult.length> 0) { %>
                                                    <% pollResult.forEach(function(item) { %>
                                                        <div class="result-item">
                                                            <div class="result-top">
                                                                <span class="result-name">
                                                                    <%= item.name %>
                                                                </span>
                                                                <span class="result-numbers">
                                                                    <%= item.vote %> vote • <%=
                                                                            item.percentage.toFixed(1) %>%
                                                                </span>
                                                            </div>
                                                            <div class="progress-track">
                                                                <div class="progress-bar"
                                                                    data-percentage="<%= item.percentage %>"></div>
                                                            </div>
                                                        </div>
                                                        <% }); %>
                                                            <% } else { %>
                                                                <div class="empty-state">
                                                                    <h2>No result yet</h2>
                                                                    <p>Vote distribution will appear here once
                                                                        participants submit their opinions.</p>
                                                                </div>
                                                                <% } %>
                                            </div>

                                            <h2 class="panel-title">Poll Summary</h2>
                                            <div class="meta-list">
                                                <div class="meta-item">
                                                    <span class="meta-label">Poll Title</span>
                                                    <div class="meta-value">
                                                        <%= poll.title %>
                                                    </div>
                                                </div>
                                                <div class="meta-item">
                                                    <span class="meta-label">Description</span>
                                                    <div class="meta-value">
                                                        <%= poll.description || "No description available" %>
                                                    </div>
                                                </div>
                                                <div class="meta-item">
                                                    <span class="meta-label">Total Options</span>
                                                    <div class="meta-value">
                                                        <%= poll.options ? poll.options.length : 0 %>
                                                    </div>
                                                </div>
                                            </div>
                                        </aside>
                                    </div>
                    </section>
                    <% } else { %>
                        <section class="hero-card">
                            <div class="empty-state">
                                <h2>Poll not found</h2>
                                <p>The poll you are trying to open does not exist or has been removed.</p>
                                <div class="actions" style="justify-content: center; margin-top: 20px;">
                                    <a class="btn btn-primary" href="/polls">Back to Poll List</a>
                                </div>
                            </div>
                        </section>
                        <% } %>
        </div>
    </div>

    <script>
        (function () {
            var bars = document.querySelectorAll(".progress-bar[data-percentage]");
            bars.forEach(function (bar) {
                var raw = Number(bar.getAttribute("data-percentage"));
                var value = Number.isFinite(raw) ? Math.min(100, Math.max(0, raw)) : 0;
                bar.style.width = value + "%";
            });
        })();
    </script>
</body>

</html>
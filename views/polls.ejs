<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Polls</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg-ink: #06141b;
            --bg-deep: #0a2430;
            --card-border: rgba(255, 255, 255, 0.18);
            --text-main: #eff8ff;
            --text-muted: #b8d0df;
            --text-soft: #d4ecf8;
            --accent: #00c2a8;
            --accent-strong: #00a08c;
            --secondary: #5b8cff;
            --soft-glow: rgba(0, 194, 168, 0.22);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            font-family: "Space Grotesk", sans-serif;
            color: var(--text-main);
            background:
                radial-gradient(1200px 700px at 92% -10%, rgba(0, 194, 168, 0.22), transparent 58%),
                radial-gradient(900px 560px at 4% 110%, rgba(91, 140, 255, 0.18), transparent 55%),
                linear-gradient(135deg, var(--bg-ink), var(--bg-deep));
        }

        .page-shell {
            min-height: 100vh;
            padding: 28px;
            position: relative;
            overflow: hidden;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            filter: blur(52px);
            opacity: 0.55;
            z-index: 0;
            animation: float 9s ease-in-out infinite;
        }

        .blob-a {
            width: 220px;
            height: 220px;
            top: 8%;
            left: 8%;
            background: rgba(0, 194, 168, 0.24);
        }

        .blob-b {
            width: 240px;
            height: 240px;
            right: 10%;
            bottom: 8%;
            background: rgba(91, 140, 255, 0.18);
            animation-delay: 2.2s;
        }

        .container {
            width: min(1120px, 100%);
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 24px;
            margin-bottom: 26px;
            animation: fadeUp 560ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: var(--text-soft);
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 999px;
            padding: 8px 12px;
            margin-bottom: 16px;
        }

        .eyebrow-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 0 8px var(--soft-glow);
        }

        h1 {
            font-size: clamp(2rem, 4.4vw, 3.2rem);
            line-height: 1.05;
            margin-bottom: 10px;
        }

        .hero-copy p {
            max-width: 62ch;
            color: var(--text-muted);
            line-height: 1.7;
            font-size: 1rem;
        }

        .hero-stats {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
            min-width: min(390px, 100%);
        }

        .stat-card {
            padding: 16px;
            border-radius: 18px;
            border: 1px solid var(--card-border);
            background: linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.05));
            backdrop-filter: blur(8px);
            box-shadow: 0 16px 40px rgba(2, 18, 24, 0.22);
        }

        .stat-label {
            display: block;
            color: var(--text-muted);
            font-size: 0.82rem;
            margin-bottom: 6px;
        }

        .stat-value {
            font-size: 1.25rem;
            font-weight: 700;
        }

        .poll-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 18px;
            animation: fadeUp 640ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
            animation-delay: 0.08s;
        }

        .poll-card {
            position: relative;
            padding: 22px;
            border-radius: 22px;
            border: 1px solid var(--card-border);
            background: linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.05));
            backdrop-filter: blur(10px);
            box-shadow: 0 20px 60px rgba(2, 18, 24, 0.32);
            transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
            overflow: hidden;
        }

        .poll-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(0, 194, 168, 0.09), transparent 45%);
            pointer-events: none;
        }

        .poll-card:hover {
            transform: translateY(-4px);
            border-color: rgba(0, 194, 168, 0.34);
            box-shadow: 0 24px 70px rgba(2, 18, 24, 0.42);
        }

        .poll-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 14px;
            margin-bottom: 14px;
            position: relative;
            z-index: 1;
        }

        .poll-title {
            font-size: 1.15rem;
            line-height: 1.35;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .poll-meta {
            font-size: 0.84rem;
            color: var(--text-muted);
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 10px;
            border-radius: 999px;
            background: rgba(0, 194, 168, 0.12);
            border: 1px solid rgba(0, 194, 168, 0.24);
            color: #aef0e5;
            font-size: 0.78rem;
            white-space: nowrap;
        }

        .badge-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 0 6px rgba(0, 194, 168, 0.15);
        }

        .poll-description {
            color: var(--text-muted);
            line-height: 1.7;
            margin-bottom: 18px;
            position: relative;
            z-index: 1;
        }

        .option-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 18px;
            position: relative;
            z-index: 1;
        }

        .option-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 12px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.14);
            color: var(--text-main);
            font-size: 0.9rem;
        }

        .option-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--secondary);
            box-shadow: 0 0 0 5px rgba(91, 140, 255, 0.14);
        }

        .poll-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            position: relative;
            z-index: 1;
        }

        .poll-footnote {
            font-size: 0.88rem;
            color: var(--text-muted);
        }

        .view-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: #05232a;
            background: linear-gradient(135deg, var(--accent), var(--accent-strong));
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 700;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            box-shadow: 0 10px 28px var(--soft-glow);
            width: 120px;
        }

        .view-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 34px rgba(0, 194, 168, 0.26);
        }

        .empty-state {
            grid-column: 1 / -1;
            padding: 44px 24px;
            border-radius: 24px;
            border: 1px dashed rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.06);
            text-align: center;
            color: var(--text-muted);
        }

        .empty-state h2 {
            color: var(--text-main);
            margin-bottom: 8px;
            font-size: 1.35rem;
        }

        .empty-state p {
            line-height: 1.7;
            max-width: 50ch;
            margin: 0 auto;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-14px);
            }
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(14px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 860px) {
            .hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .hero-stats {
                width: 100%;
                min-width: 0;
            }
        }

        @media (max-width: 640px) {
            .page-shell {
                padding: 16px;
            }

            .hero-stats {
                grid-template-columns: 1fr;
            }

            .poll-card {
                padding: 18px;
            }

            .poll-footer {
                flex-direction: column;
                align-items: flex-start;
            }

            .view-link {
                width: 100%;
                justify-content: center;
            }
        }

        @media (prefers-reduced-motion: reduce) {

            *,
            *::before,
            *::after {
                animation: none !important;
                transition: none !important;
            }
        }
    </style>
</head>

<body>
    <div class="page-shell">
        <div class="blob blob-a" aria-hidden="true"></div>
        <div class="blob blob-b" aria-hidden="true"></div>

        <div class="container">
            <section class="hero">
                <div class="hero-copy">
                    <div class="eyebrow">
                        <span class="eyebrow-dot"></span>
                        Poll Dashboard
                    </div>
                    <h1>Your All Polls</h1>
                    <p>
                        Manage, review, and share all of your polls in one organized view.
                        Each card gives a quick summary of the poll and its available options.
                    </p>
                </div>

                <div class="hero-stats">
                    <div class="stat-card">
                        <span class="stat-label">Total Polls</span>
                        <span class="stat-value">
                            <%= polls.length %>
                        </span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-label">Active This Week</span>
                        <span class="stat-value">
                            <%= polls.length %>
                        </span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-label">Available Options</span>
                        <span class="stat-value">
                            <%= polls.reduce((total, poll)=> total + (poll.options ? poll.options.length : 0), 0) %>
                        </span>
                    </div>
                </div>
            </section>

            <section class="poll-grid">
                <% if (polls && polls.length> 0) { %>
                    <% polls.forEach(function(poll, index) { %>
                        <article class="poll-card">
                            <div class="poll-top">
                                <div>
                                    <h2 class="poll-title">
                                        <%= poll.title %>
                                    </h2>
                                    <div class="poll-meta">
                                        Poll #<%= index + 1 %> • <%= poll.options ? poll.options.length : 0 %> options
                                    </div>
                                </div>

                                <div class="badge">
                                    <span class="badge-dot"></span>
                                    Live Poll
                                </div>
                            </div>

                            <% if (poll.description) { %>
                                <p class="poll-description">
                                    <%= poll.description %>
                                </p>
                                <% } else { %>
                                    <p class="poll-description">No description was added for this poll.</p>
                                    <% } %>

                                        <div class="option-list">
                                            <% if (poll.options && poll.options.length> 0) { %>
                                                <% poll.options.forEach(function(option) { %>
                                                    <span class="option-pill">
                                                        <span class="option-dot"></span>
                                                        <%= option.name %>
                                                    </span>
                                                    <% }); %>
                                                        <% } else { %>
                                                            <span class="option-pill">
                                                                <span class="option-dot"></span>
                                                                No options available
                                                            </span>
                                                            <% } %>
                                        </div>

                                        <div class="poll-footer">
                                            <span class="poll-footnote">Created for quick voting and clean
                                                tracking</span>
                                            <a class="view-link" href="#">
                                                View Details
                                            </a>
                                        </div>
                        </article>
                        <% }); %>
                            <% } else { %>
                                <div class="empty-state">
                                    <h2>No polls yet</h2>
                                    <p>Once you create a poll, it will appear here in a modern card layout with its
                                        title, description, and options.</p>
                                </div>
                                <% } %>
            </section>
        </div>
    </div>
</body>

</html>
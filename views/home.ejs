<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Available</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg-ink: #06141b;
            --bg-deep: #0a2430;
            --card: rgba(255, 255, 255, 0.08);
            --card-border: rgba(255, 255, 255, 0.2);
            --text-main: #eff8ff;
            --text-muted: #b8d0df;
            --accent: #00c2a8;
            --accent-strong: #00a08c;
            --soft-glow: rgba(0, 194, 168, 0.24);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            font-family: "Space Grotesk", sans-serif;
            color: var(--text-main);
            background:
                radial-gradient(1200px 700px at 90% -10%, rgba(0, 194, 168, 0.25), transparent 60%),
                radial-gradient(900px 560px at 8% 110%, rgba(255, 170, 98, 0.22), transparent 56%),
                linear-gradient(135deg, var(--bg-ink), var(--bg-deep));
            overflow: hidden;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            filter: blur(48px);
            opacity: 0.55;
            z-index: 0;
            animation: float 8s ease-in-out infinite;
        }

        .blob-a {
            width: 220px;
            height: 220px;
            top: 9%;
            left: 12%;
            background: rgba(0, 194, 168, 0.28);
        }

        .blob-b {
            width: 260px;
            height: 260px;
            right: 8%;
            bottom: 4%;
            background: rgba(255, 170, 98, 0.22);
            animation-delay: 1.8s;
        }

        .state-card {
            width: min(680px, 100%);
            position: relative;
            z-index: 1;
            padding: clamp(24px, 4vw, 40px);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            background: linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.05));
            backdrop-filter: blur(8px);
            box-shadow:
                0 24px 70px rgba(2, 18, 24, 0.56),
                inset 0 1px 0 rgba(255, 255, 255, 0.25);
            animation: reveal 620ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            color: #d4ecf8;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.22);
            border-radius: 999px;
            padding: 8px 12px;
            margin-bottom: 18px;
        }

        .dot {
            position: relative;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 0 8px var(--soft-glow);
            animation: dotPulse 1.8s ease-in-out infinite;
        }

        .dot::after {
            content: "";
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            border: 1px solid rgba(0, 194, 168, 0.65);
            animation: dotRipple 1.8s ease-out infinite;
        }

        .status {
            animation: reveal 620ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
            animation-delay: 0.3s;
            margin-left: 8px;
        }

        h1 {
            font-size: clamp(1.55rem, 4vw, 2.6rem);
            line-height: 1.2;
            font-weight: 700;
            margin-bottom: 12px;
        }

        p {
            font-size: clamp(0.95rem, 2.4vw, 1.08rem);
            line-height: 1.7;
            color: var(--text-muted);
            max-width: 58ch;
        }

        .actions {
            margin-top: 28px;
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .btn {
            appearance: none;
            text-decoration: none;
            border-radius: 12px;
            padding: 12px 18px;
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        .btn-primary {
            color: #05232a;
            background: var(--accent);
            box-shadow: 0 8px 24px var(--soft-glow);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            background: var(--accent-strong);
        }

        .btn-secondary {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.24);
        }

        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
            background: rgba(255, 255, 255, 0.16);
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-14px);
            }
        }

        @keyframes reveal {
            from {
                opacity: 0;
                transform: translateY(12px) scale(0.985);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @keyframes dotPulse {

            0%,
            100% {
                transform: scale(1);
                box-shadow: 0 0 0 8px var(--soft-glow);
            }

            50% {
                transform: scale(1.12);
                box-shadow: 0 0 0 12px rgba(0, 194, 168, 0.14);
            }
        }

        @keyframes dotRipple {
            0% {
                opacity: 0.75;
                transform: scale(0.82);
            }

            70%,
            100% {
                opacity: 0;
                transform: scale(1.7);
            }
        }

        @media (prefers-reduced-motion: reduce) {

            .dot,
            .dot::after {
                animation: none;
            }
        }

        @media (max-width: 560px) {
            body {
                padding: 16px;
            }

            .state-card {
                border-radius: 18px;
            }

            .actions {
                flex-direction: column;
            }

            .btn {
                text-align: center;
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="blob blob-a" aria-hidden="true"></div>
    <div class="blob blob-b" aria-hidden="true"></div>

    <main class="state-card">
        <div class="eyebrow">
            <span class="dot"></span>
            <span class="status">Status: Empty State</span>
        </div>
        <h1>Oops! There is nothing to show here.</h1>
        <p>
            The content you are looking for is not available right now. It may have been moved,
            removed, or is still under preparation.
        </p>

        <div class="actions">
            <a class="btn btn-primary" href="/create">Create a New Poll</a>
            <a class="btn btn-secondary" href="javascript:history.back()">Return to Previous Page</a>
        </div>
    </main>
</body>

</html>